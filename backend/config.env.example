# Puerto del servidor
PORT=5000

# Base de datos MongoDB
MONGODB_URI=mongodb://localhost:27017/cuentos-personalizados

# JWT Secret (usar una clave segura en producción)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Firebase Configuration (for production deployment)
FIREBASE_PROJECT_ID=cuentacuentos-b2e64
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@cuentacuentos-b2e64.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=cuentacuentos-b2e64.firebasestorage.app
# Alternative environment variables for Google Cloud
GOOGLE_PROJECT_ID=cuentacuentos-b2e64
GOOGLE_CLOUD_PROJECT=cuentacuentos-b2e64

# URLs del frontend
FRONTEND_URL=http://localhost:3000

# Configuración de Email
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-or-oauth-token
EMAIL_FROM=your-email@gmail.com

# Para Gmail, necesitas activar "App Passwords" en tu cuenta de Google:
# 1. Ir a https://myaccount.google.com/security
# 2. Activar autenticación de dos factores
# 3. Generar una contraseña de aplicación
# 4. Usar esa contraseña en EMAIL_PASS

# Configuración de desarrollo
NODE_ENV=development

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100 