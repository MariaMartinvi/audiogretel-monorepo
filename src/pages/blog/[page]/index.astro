---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { ui } from '../../../i18n/ui';
import BlogCard from '../../../components/blog/BlogCard.astro';
import BlogSidebar from '../../../components/blog/BlogSidebar.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blogEs');
  const POSTS_PER_PAGE = 10;
  const totalPages = Math.max(1, Math.ceil(allPosts.length / POSTS_PER_PAGE));
  return Array.from({ length: totalPages - 1 }, (_, i) => ({
    params: { page: String(i + 2) },
  }));
}

const POSTS_PER_PAGE = 10;
const lang = 'es';
const baseUrl = '';
const t = ui[lang].blog;

const { page } = Astro.params;
const currentPage = Number(page) || 2;

const allPosts = await getCollection('blogEs');
const sorted = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const totalPages = Math.max(1, Math.ceil(sorted.length / POSTS_PER_PAGE));
const start = (currentPage - 1) * POSTS_PER_PAGE;
const posts = sorted.slice(start, start + POSTS_PER_PAGE);

const categories = [...new Set(sorted.map((p) => p.data.category))].sort();
const recentPosts = sorted.slice(0, 5).map((p) => ({ slug: p.slug, title: p.data.title }));
---

<BaseLayout lang={lang} title={t.title} description={t.description}>
  <h1 class="blog-page-title">{t.title}</h1>
  <p class="blog-page-description">{t.description}</p>

  <div class="blog-layout">
    <div class="blog-list-wrap">
      <div class="blog-list">
        {posts.map((entry) => (
          <BlogCard
            slug={entry.slug}
            title={entry.data.title}
            excerpt={entry.data.excerpt}
            date={entry.data.date}
            author={entry.data.author}
            category={entry.data.category}
            featuredImage={entry.data.featuredImage}
            baseUrl={baseUrl}
            readingTime={3}
          />
        ))}
      </div>
      <nav class="blog-pagination" aria-label="Paginación">
        <a href={currentPage === 2 ? '/blog' : `/blog/${currentPage - 1}`}>{t.prev}</a>
        <span>{t.page} {currentPage} / {totalPages}</span>
        {currentPage < totalPages ? (
          <a href={`/blog/${currentPage + 1}`}>{t.next}</a>
        ) : (
          <span />
        )}
      </nav>
    </div>
    <BlogSidebar lang={lang} categories={categories} recentPosts={recentPosts} baseUrl={baseUrl} />
  </div>
</BaseLayout>
