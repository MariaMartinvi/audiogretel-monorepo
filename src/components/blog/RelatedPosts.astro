---
interface Props {
  posts: { slug: string; title: string }[];
  baseUrl: string;
  title?: string;
}

const { posts, baseUrl, title = 'Artículos relacionados' } = Astro.props;
---

{posts.length > 0 && (
  <aside class="related-posts">
    <h2 class="related-posts-title">{title}</h2>
    <ul class="related-posts-list">
      {posts.map((p) => (
        <li><a href={`${baseUrl}/blog/${p.slug}`}>{p.title}</a></li>
      ))}
    </ul>
  </aside>
)}

<style>
  .related-posts { margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--color-border); }
  .related-posts-title { font-size: 1.1rem; margin: 0 0 0.75rem; }
  .related-posts-list { list-style: none; margin: 0; padding: 0; }
  .related-posts-list li { margin-bottom: 0.5rem; }
</style>
